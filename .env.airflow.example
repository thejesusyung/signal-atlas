# .env.airflow.example — Airflow EC2 (on-demand, spins up for DAG runs)
# Copy to .env.airflow and fill in all placeholder values.
# IMPORTANT: MLFLOW_TRACKING_URI must point to the 2GB EC2's private IP, not localhost.

APP_ENV=production
LOG_LEVEL=INFO
PYTHONPATH=/opt/project/src

# --- RDS PostgreSQL ---
POSTGRES_HOST=<your-rds-endpoint>.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=news_pipeline
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=news_pipeline

DATABASE_URL=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/news_pipeline

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__DAGS_FOLDER=/opt/project/dags
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/airflow_metadata
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in SSM. NEVER regenerate — changing this breaks encrypted Airflow connections.
AIRFLOW__CORE__FERNET_KEY=<generated-fernet-key>
AIRFLOW_HOME=/opt/airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=<strong-password>
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_DB_NAME=airflow_metadata

# --- MLflow (remote — points to 2GB EC2 private IP) ---
# Use the private IP of the 2GB EC2 (both instances must be in the same VPC).
# Security group on 2GB EC2 must allow inbound TCP 5000 from Airflow EC2 SG.
MLFLOW_TRACKING_URI=http://<2gb-ec2-private-ip>:5000
MLFLOW_ARTIFACT_ROOT=/opt/project/mlruns
MLFLOW_EXPERIMENT_INGESTION=ingestion_monitoring
MLFLOW_EXPERIMENT_EXTRACTION=extraction_monitoring
MLFLOW_EXPERIMENT_SIGNALS=signal_monitoring
MLFLOW_EXPERIMENT_SIMULATION=simulation_cycles

# --- LLM ---
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RATE_LIMIT_BACKEND=auto

# --- Ingestion / Extraction ---
INGESTION_BATCH_SIZE=100
EXTRACTION_BATCH_SIZE=20
FEEDS_CONFIG_PATH=/opt/project/config/feeds.yaml
FEED_STATE_PATH=/opt/project/data/feed_state.json
SCRAPER_USER_AGENT=NewsIntelligencePipeline/0.1
SCRAPER_DOMAIN_DELAY_SECONDS=2.0
DEDUP_RECENT_HOURS=48
DEDUP_TITLE_SIMILARITY=0.92

# --- Embeddings / Signals ---
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MIN_CLUSTER_SIZE=5
SIGNAL_BASELINE_RUNS=10
SIGNAL_ZSCORE_THRESHOLD=1.5
SIGNAL_TOP_N=3
SIGNAL_CURRENT_WINDOW_HOURS=24
SIGNAL_BASELINE_WINDOW_HOURS=72
TOPIC_LABELS=technology,politics,business,science,health,entertainment,sports,world

# --- Simulation ---
SIM_WRITERS_CONFIG_PATH=/opt/project/config/writers.yaml
SIM_PERSONAS_CONFIG_PATH=/opt/project/config/personas.yaml
SIM_PERSONAS_PER_TWEET=60
SIM_CYCLE_TOP_STORIES=6
SIM_BOTTOM_N_MUTATE=3

# --- FastAPI (not used on Airflow EC2, but config.py reads these) ---
API_HOST=0.0.0.0
API_PORT=8000
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100
