PYTHONPATH=/opt/project/src
APP_ENV=development
LOG_LEVEL=INFO

POSTGRES_DB=news_pipeline
POSTGRES_USER=news_pipeline
POSTGRES_PASSWORD=news_pipeline
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://news_pipeline:news_pipeline@postgres:5432/news_pipeline
AIRFLOW_DB_NAME=airflow_metadata
MLFLOW_DB_NAME=mlflow_tracking

AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__DAGS_FOLDER=/opt/project/dags
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://news_pipeline:news_pipeline@postgres:5432/airflow_metadata
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_HOME=/opt/airflow

MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://news_pipeline:news_pipeline@postgres:5432/mlflow_tracking
MLFLOW_ARTIFACT_ROOT=/opt/project/mlruns
MLFLOW_EXPERIMENT_INGESTION=ingestion_monitoring
MLFLOW_EXPERIMENT_EXTRACTION=extraction_monitoring

API_HOST=0.0.0.0
API_PORT=8000
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

INGESTION_BATCH_SIZE=100
EXTRACTION_BATCH_SIZE=20
FEEDS_CONFIG_PATH=/opt/project/config/feeds.yaml
FEED_STATE_PATH=/opt/project/data/feed_state.json
SCRAPER_USER_AGENT=NewsIntelligencePipeline/0.1 (+https://localhost)
SCRAPER_DOMAIN_DELAY_SECONDS=2.0
DEDUP_RECENT_HOURS=48
DEDUP_TITLE_SIMILARITY=0.92

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RATE_LIMIT_BACKEND=auto
TOPIC_LABELS=technology,politics,business,science,health,entertainment,sports,world
