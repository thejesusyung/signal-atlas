# .env.aws.example — AWS-native setup (App Runner + ECS Fargate, zero EC2)
# Copy to .env.aws and fill in real values.
# This file is used by all three pipeline tasks AND both App Runner services.
# Store as a single Secrets Manager secret: /pet-signal-atlas/prod/env

APP_ENV=production
LOG_LEVEL=INFO
PYTHONPATH=/opt/project/src

# --- RDS PostgreSQL ---
POSTGRES_HOST=<your-rds-endpoint>.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=news_pipeline
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=news_pipeline
DATABASE_URL=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/news_pipeline

# --- MLflow (App Runner service, scale-to-zero) ---
# After deploying MLflow App Runner, paste its URL here (no trailing slash)
MLFLOW_TRACKING_URI=https://<mlflow-apprunner-id>.us-east-2.awsapprunner.com
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/mlflow_tracking
MLFLOW_ARTIFACT_ROOT=s3://pet-signal-atlas-mlflow-artifacts/mlruns
MLFLOW_EXPERIMENT_INGESTION=ingestion_monitoring
MLFLOW_EXPERIMENT_EXTRACTION=extraction_monitoring
MLFLOW_EXPERIMENT_SIGNALS=signal_monitoring
MLFLOW_EXPERIMENT_SIMULATION=simulation_cycles

# --- FastAPI (App Runner service, scale-to-zero) ---
API_HOST=0.0.0.0
API_PORT=8000
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# --- ECS trigger (ingestion task uses these to launch extraction) ---
ECS_CLUSTER=pet-signal-atlas
ECS_EXTRACTION_TASK_DEF=pet-signal-atlas-extraction:1
ECS_SUBNET_IDS=subnet-<id1>,subnet-<id2>
ECS_SECURITY_GROUP_ID=sg-<id>

# --- LLM providers ---
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1

OPENROUTER_API_KEY=<your-openrouter-api-key>
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_INFERENCE_PROVIDER=open-inference/int8
OPENROUTER_REASONING_EFFORT=medium

LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RATE_LIMIT_BACKEND=auto

# --- Ingestion / scraping ---
INGESTION_BATCH_SIZE=100
EXTRACTION_BATCH_SIZE=20
FEEDS_CONFIG_PATH=/opt/project/config/feeds.yaml
FEED_STATE_PATH=/tmp/feed_state.json
SCRAPER_USER_AGENT=NewsIntelligencePipeline/0.1
SCRAPER_DOMAIN_DELAY_SECONDS=2.0
DEDUP_RECENT_HOURS=48
DEDUP_TITLE_SIMILARITY=0.92

# --- Embeddings / signals ---
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MIN_CLUSTER_SIZE=5
SIGNAL_BASELINE_RUNS=10
SIGNAL_ZSCORE_THRESHOLD=1.5
SIGNAL_TOP_N=3
SIGNAL_CURRENT_WINDOW_HOURS=24
SIGNAL_BASELINE_WINDOW_HOURS=72
TOPIC_LABELS=technology,politics,business,science,health,entertainment,sports,world,environment,finance,education,crime,climate

# --- Simulation ---
SIM_WRITERS_CONFIG_PATH=/opt/project/config/writers.yaml
SIM_PERSONAS_CONFIG_PATH=/opt/project/config/personas.yaml
SIM_PERSONAS_PER_TWEET=60
SIM_CYCLE_TOP_STORIES=6
SIM_BOTTOM_N_MUTATE=3
