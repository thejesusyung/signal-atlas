# .env.prod.example — 2GB EC2 (API + MLflow, always-on)
# Copy to .env.prod and fill in RDS endpoint and passwords.

APP_ENV=production
LOG_LEVEL=INFO
PYTHONPATH=/opt/project/src

# --- RDS PostgreSQL ---
POSTGRES_HOST=<your-rds-endpoint>.rds.amazonaws.com
POSTGRES_PORT=5432
POSTGRES_USER=news_pipeline
POSTGRES_PASSWORD=<strong-password>
POSTGRES_DB=news_pipeline

# Main app database
DATABASE_URL=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/news_pipeline

# --- MLflow (this EC2 IS the MLflow host) ---
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_BACKEND_STORE_URI=postgresql+psycopg2://news_pipeline:<password>@<rds-endpoint>:5432/mlflow_tracking
MLFLOW_ARTIFACT_ROOT=/opt/project/mlruns
MLFLOW_EXPERIMENT_INGESTION=ingestion_monitoring
MLFLOW_EXPERIMENT_EXTRACTION=extraction_monitoring
MLFLOW_EXPERIMENT_SIGNALS=signal_monitoring
MLFLOW_EXPERIMENT_SIMULATION=simulation_cycles

# --- FastAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# --- Not used by API/MLflow; included so pydantic-settings doesn't error ---
# Leave blank or omit entirely.
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=5
LLM_REQUESTS_PER_MINUTE=20
LLM_RATE_LIMIT_BACKEND=auto
INGESTION_BATCH_SIZE=100
EXTRACTION_BATCH_SIZE=20
FEEDS_CONFIG_PATH=/opt/project/config/feeds.yaml
FEED_STATE_PATH=/opt/project/data/feed_state.json
SCRAPER_USER_AGENT=NewsIntelligencePipeline/0.1
SCRAPER_DOMAIN_DELAY_SECONDS=2.0
DEDUP_RECENT_HOURS=48
DEDUP_TITLE_SIMILARITY=0.92
EMBEDDING_BATCH_SIZE=64
EMBEDDING_MIN_CLUSTER_SIZE=5
SIGNAL_BASELINE_RUNS=10
SIGNAL_ZSCORE_THRESHOLD=1.5
SIGNAL_TOP_N=3
SIGNAL_CURRENT_WINDOW_HOURS=24
SIGNAL_BASELINE_WINDOW_HOURS=72
TOPIC_LABELS=technology,politics,business,science,health,entertainment,sports,world
SIM_WRITERS_CONFIG_PATH=/opt/project/config/writers.yaml
SIM_PERSONAS_CONFIG_PATH=/opt/project/config/personas.yaml
SIM_PERSONAS_PER_TWEET=60
SIM_CYCLE_TOP_STORIES=6
SIM_BOTTOM_N_MUTATE=3
